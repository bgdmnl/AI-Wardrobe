# Database (PostgreSQL; falls back to SQLite wardrobe.db if unavailable)
DATABASE_URL=postgresql+asyncpg://wardrobe:wardrobe@localhost:5432/wardrobe

# Redis (optional — local asyncio worker fallback when unavailable)
REDIS_HOST=localhost
REDIS_PORT=6379

# File Storage
UPLOAD_DIR=./uploads

# ── AI Provider ──────────────────────────────────────────────
# Options: mock (default), ollama, openai
AI_PROVIDER=mock

# Comma-separated endpoints for fallback retries
AI_ENDPOINTS=http://localhost:11434

# Vision model (image analysis) and text model (descriptions, outfits)
AI_VISION_MODEL=llava
AI_TEXT_MODEL=llama3

AI_TIMEOUT=60
AI_MAX_RETRIES=3

# API key (required for OpenAI; optional for local Ollama)
AI_API_KEY=
OPENAI_API_KEY=

# ── Ollama (local, free, Windows-friendly) ───────────────────
# 1. Install Ollama: https://ollama.com
# 2. Pull models:  ollama pull llava && ollama pull llama3
# 3. Set:
#    AI_PROVIDER=ollama
#    AI_ENDPOINTS=http://localhost:11434
#    AI_VISION_MODEL=llava
#    AI_TEXT_MODEL=llama3

# ── OpenAI (cloud, best quality) ─────────────────────────────
#    AI_PROVIDER=openai
#    AI_ENDPOINTS=https://api.openai.com
#    AI_VISION_MODEL=gpt-4o
#    AI_TEXT_MODEL=gpt-4o
#    OPENAI_API_KEY=sk-your-key-here

# CORS
AI_PROVIDER=ollama
AI_ENDPOINTS=http://localhost:11434
AI_VISION_MODEL=llava
AI_TEXT_MODEL=llama3
AI_TIMEOUT=120

CORS_ORIGINS=http://localhost:3000,http://192.168.1.141:3000,http://192.168.1.128:3000

